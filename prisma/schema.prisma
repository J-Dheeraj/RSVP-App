generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
}

model Venue {
  id          String   @id @default(cuid())
  name        String
  address     String?
  city        String   @default("Singapore")
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  events      Event[]
}

model Event {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  date        DateTime
  venueId     String
  venue       Venue    @relation(fields: [venueId], references: [id])
  description String?
  // "wedding" uses zone-based allocation; "other" supports manual/auto
  type        String   @default("other")
  // allocation: "zone" | "auto" | "manual"
  allocation  String   @default("auto")
  maxPerTable Int      @default(10)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  tables      Table[]
  zones       Zone[]
  rsvps       RSVP[]
}

model Zone {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name    String
  label   String
  color   String @default("#6366f1")

  tables  Table[]
}

model Table {
  id       String  @id @default(cuid())
  eventId  String
  event    Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  zoneId   String?
  zone     Zone?   @relation(fields: [zoneId], references: [id])
  number   Int
  label    String?
  capacity Int     @default(10)

  rsvps    RSVP[]

  @@unique([eventId, number])
}

model RSVP {
  id             String   @id @default(cuid())
  eventId        String
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tableId        String?
  table          Table?   @relation(fields: [tableId], references: [id])

  guestName      String
  email          String?
  phone          String?
  guestCount     Int      @default(1)
  relationship   String?

  needsTransport Boolean  @default(false)
  pickupLocation String?

  dietaryNeeds   String?
  message        String?
  adminNotes     String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
