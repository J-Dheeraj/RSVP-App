# Copy this file to .env and fill in the values before running the app.
# NEVER commit .env to version control.

# SQLite for local dev. Switch to PostgreSQL for production:
#   postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL="file:./dev.db"

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 random bytes. Must be changed from this placeholder before deploying.
NEXTAUTH_SECRET="REPLACE_THIS_WITH_OUTPUT_OF_COMMAND_ABOVE"

# Set to your exact production URL (no trailing slash). NextAuth uses this for CSRF protection.
# Mismatch between this value and the actual domain will break login.
NEXTAUTH_URL="http://localhost:3000"
